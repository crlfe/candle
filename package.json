{
  "name": "candle",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "bin": "./dist/cli.js",
  "type": "module",
  "imports": {
    "#hot": "./hot/index.ts",
    "#jsx": "./jsx/index.ts",
    "#jsx/jsx-runtime": "./jsx/jsx-runtime.ts",
    "#util": "./util/index.ts"
  },
  "exports": {
    "./hot": {
      "types": "./hot/index.ts",
      "node": "./dist/hot.js"
    },
    "./hot-register": {
      "types": "./hot/register.ts",
      "node": "./dist/hot-register.js"
    },
    "./jsx": {
      "types": "./jsx/index.ts",
      "import": "./dist/jsx.js"
    },
    "./jsx/jsx-runtime": {
      "types": "./jsx/jsx-runtime.ts",
      "import": "./dist/jsx-jsx-runtime.js"
    },
    "./util": {
      "types": "./util/index.ts",
      "import": "./dist/util.js"
    }
  },
  "scripts": {
    "build": "./cli/index.ts build --delete --verbose",
    "lint": "oxlint && oxfmt --check",
    "serve": "./cli/index.ts serve --verbose",
    "test": "node --test",
    "watch": "./cli/index.ts build --delete --verbose --watch"
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "mime-types": "^3.0.2",
    "oxc-parser": "^0.115.0",
    "oxc-transform": "^0.116.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "rolldown": "1.0.0-rc.7"
  },
  "packageManager": "pnpm@10.30.1",
  "minimumReleaseAge": 10080
}
