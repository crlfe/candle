{
  "compilerOptions": {
    "noEmit": true,

    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,

    "jsx": "react-jsx",
    "jsxImportSource": "#jsx",

    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "exclude": ["**/dist", "**/node_modules"]
}
